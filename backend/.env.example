SECRET_KEY=your-secret-key-here
DATABASE_URL=mysql://breathe_db:YOUR_PASSWORD@127.0.0.1:3306/breathe_db
# If the password contains special characters like @, encode them using percent-encoding.
# Example: mysql://breathe_db:Raj%4076330Raj@127.0.0.1:3306/breathe_db
DEBUG=False
ALLOWED_HOSTS=your-domain.railway.app,localhost
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
